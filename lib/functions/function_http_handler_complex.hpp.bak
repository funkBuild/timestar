#ifndef __FUNCTION_HTTP_HANDLER_H_INCLUDED__
#define __FUNCTION_HTTP_HANDLER_H_INCLUDED__

#include "http_query_handler.hpp"
#include "../query/function_query_parser.hpp"
#include "../query/function_pipeline_executor.hpp"
#include "../functions/function_registry.hpp"
#include <seastar/http/httpd.hh>
#include <seastar/http/handlers.hh>
#include <seastar/http/function_handlers.hh>
#include <seastar/core/future.hh>
#include <seastar/core/sharded.hh>
#include <glaze/glaze.hpp>

// Forward declaration
class Engine;

namespace tsdb {

// Enhanced query request that supports functions
struct GlazeFunctionQueryRequest {
    std::string query;
    uint64_t startTime;
    uint64_t endTime;
    std::optional<std::string> aggregationInterval;
    std::optional<bool> enableFunctions = true;  // Enable function parsing
    std::optional<size_t> maxPoints = 100000;    // Limit result size
    std::optional<bool> enableOptimizations = true;
    std::optional<bool> enableCache = true;      // Enable function result caching
};

// Function query response with enhanced metadata
struct FunctionQueryResponse {
    bool success = false;
    std::vector<SeriesResult> series;
    QueryStatistics statistics;
    std::string errorMessage;
    std::string errorCode;
    
    // Function-specific metadata
    struct FunctionMetadata {
        std::vector<std::string> functionsExecuted;
        size_t totalFunctionExecutions = 0;
        double totalFunctionTimeMs = 0.0;
        std::map<std::string, std::string> performanceMetrics;
    } functionMetadata;
    
    // Original request for debugging
    std::optional<std::string> originalQuery;
    std::optional<std::string> parsedQuery;  // Show how query was interpreted
};

// Function registry API response
struct FunctionRegistryResponse {
    bool success = false;
    std::vector<functions::FunctionMetadata> functions;
    std::map<std::string, size_t> categoryCounts;
    std::string errorMessage;
};

// Function validation response
struct FunctionValidationResponse {
    bool valid = false;
    std::string functionName;
    std::vector<std::string> errors;
    std::vector<std::string> warnings;
    std::optional<functions::FunctionMetadata> metadata;
};

class FunctionHttpHandler {
private:
    seastar::sharded<Engine>* engineSharded;
    seastar::sharded<LevelDBIndex>* indexSharded;
    std::unique_ptr<FunctionPipelineExecutor> executor;
    std::unique_ptr<FunctionResultCache> cache;
    
public:
    explicit FunctionHttpHandler(
        seastar::sharded<Engine>* engine,
        seastar::sharded<LevelDBIndex>* index = nullptr
    ) : engineSharded(engine), indexSharded(index),
        executor(std::make_unique<FunctionPipelineExecutor>(engine, index)),
        cache(std::make_unique<FunctionResultCache>()) {}
    
    // Register routes with HTTP server
    void registerRoutes(seastar::httpd::routes& r);
    
    // Main function query endpoint: POST /query/functions
    seastar::future<std::unique_ptr<seastar::http::reply>>
    handleFunctionQuery(std::unique_ptr<seastar::http::request> req);
    
    // Function registry endpoints
    seastar::future<std::unique_ptr<seastar::http::reply>>
    handleGetFunctions(std::unique_ptr<seastar::http::request> req);
    
    seastar::future<std::unique_ptr<seastar::http::reply>>
    handleGetFunction(std::unique_ptr<seastar::http::request> req);
    
    seastar::future<std::unique_ptr<seastar::http::reply>>
    handleValidateFunction(std::unique_ptr<seastar::http::request> req);
    
    // Function execution endpoints
    seastar::future<std::unique_ptr<seastar::http::reply>>
    handleExecuteFunction(std::unique_ptr<seastar::http::request> req);
    
    // Performance monitoring endpoints
    seastar::future<std::unique_ptr<seastar::http::reply>>
    handleGetPerformanceStats(std::unique_ptr<seastar::http::request> req);
    
    seastar::future<std::unique_ptr<seastar::http::reply>>
    handleGetCacheStats(std::unique_ptr<seastar::http::request> req);
    
    // Utility endpoints
    seastar::future<std::unique_ptr<seastar::http::reply>>
    handleParseQuery(std::unique_ptr<seastar::http::request> req);
    
private:
    // Execute function query
    seastar::future<FunctionQueryResponse> executeFunctionQuery(
        const GlazeFunctionQueryRequest& request
    );
    
    // Format responses
    std::string formatFunctionQueryResponse(const FunctionQueryResponse& response);
    std::string formatFunctionRegistryResponse(const FunctionRegistryResponse& response);
    std::string formatValidationResponse(const FunctionValidationResponse& response);
    std::string formatPerformanceStats();
    std::string formatCacheStats();
    
    // Error handling
    std::string createFunctionErrorResponse(const std::string& code, const std::string& message);
    FunctionQueryResponse createErrorQueryResponse(const std::string& code, const std::string& message);
    
    // Request parsing
    GlazeFunctionQueryRequest parseFunctionQueryRequest(const std::string& body);
    
    // Query optimization
    FunctionQueryRequest optimizeQuery(const FunctionQueryRequest& query);
    
    // Cache management
    bool shouldUseCache(const GlazeFunctionQueryRequest& request);
    std::string generateCacheKey(const GlazeFunctionQueryRequest& request);
    
    // Response transformation
    FunctionQueryResponse transformExecutorResult(const FunctionQueryResult& result);
    
    // Performance monitoring
    void recordQueryExecution(const GlazeFunctionQueryRequest& request, 
                            const FunctionQueryResponse& response);
};

// Function examples and documentation generator
class FunctionDocumentationHandler {
public:
    // Generate documentation for all functions
    static std::string generateFunctionDocs();
    
    // Generate examples for a specific function
    static std::string generateFunctionExamples(const std::string& functionName);
    
    // Generate query syntax help
    static std::string generateQuerySyntaxHelp();
    
    // Generate interactive examples
    static std::string generateInteractiveExamples();
    
private:
    static std::string formatFunctionMetadata(const functions::FunctionMetadata& metadata);
    static std::vector<std::string> generateExampleQueries(const std::string& functionName);
};

// Function query builder for complex queries
class FunctionQueryBuilder {
private:
    std::string measurement;
    std::vector<std::string> fields;
    std::map<std::string, std::string> scopes;
    std::vector<std::string> groupByTags;
    AggregationMethod aggregation = AggregationMethod::AVG;
    std::vector<FunctionCall> pipeline;
    
public:
    // Builder methods
    FunctionQueryBuilder& setMeasurement(const std::string& m) { measurement = m; return *this; }
    FunctionQueryBuilder& addField(const std::string& field) { fields.push_back(field); return *this; }
    FunctionQueryBuilder& addScope(const std::string& key, const std::string& value) { 
        scopes[key] = value; return *this; 
    }
    FunctionQueryBuilder& setAggregation(AggregationMethod agg) { aggregation = agg; return *this; }
    FunctionQueryBuilder& addFunction(const FunctionCall& func) { pipeline.push_back(func); return *this; }
    
    // Convenience methods for common functions
    FunctionQueryBuilder& sma(int window) {
        FunctionCall func;
        func.name = "sma";
        func.parameters["window"] = static_cast<int64_t>(window);
        return addFunction(func);
    }
    
    FunctionQueryBuilder& interpolate(const std::string& method, int64_t interval) {
        FunctionCall func;
        func.name = "linear_interpolate";
        func.parameters["method"] = method;
        func.parameters["target_interval"] = interval;
        return addFunction(func);
    }
    
    FunctionQueryBuilder& scale(double factor) {
        FunctionCall func;
        func.name = "scale";
        func.parameters["factor"] = factor;
        return addFunction(func);
    }
    
    // Build the query
    FunctionQueryRequest build(uint64_t startTime, uint64_t endTime);
    std::string buildQueryString();
};

// Error codes for function operations
namespace function_error_codes {
    const std::string INVALID_FUNCTION_QUERY = "INVALID_FUNCTION_QUERY";
    const std::string FUNCTION_NOT_FOUND = "FUNCTION_NOT_FOUND";
    const std::string PARAMETER_VALIDATION_ERROR = "PARAMETER_VALIDATION_ERROR";
    const std::string FUNCTION_EXECUTION_ERROR = "FUNCTION_EXECUTION_ERROR";
    const std::string INSUFFICIENT_DATA = "INSUFFICIENT_DATA";
    const std::string MEMORY_LIMIT_EXCEEDED = "MEMORY_LIMIT_EXCEEDED";
    const std::string TIMEOUT_ERROR = "TIMEOUT_ERROR";
    const std::string CACHE_ERROR = "CACHE_ERROR";
}

} // namespace tsdb

// Glaze serialization for HTTP requests/responses
template<>
struct glz::meta<tsdb::GlazeFunctionQueryRequest> {
    using T = tsdb::GlazeFunctionQueryRequest;
    static constexpr auto value = object(
        "query", &T::query,
        "startTime", &T::startTime,
        "endTime", &T::endTime,
        "aggregationInterval", &T::aggregationInterval,
        "enableFunctions", &T::enableFunctions,
        "maxPoints", &T::maxPoints,
        "enableOptimizations", &T::enableOptimizations,
        "enableCache", &T::enableCache
    );
};

template<>
struct glz::meta<tsdb::FunctionQueryResponse> {
    using T = tsdb::FunctionQueryResponse;
    static constexpr auto value = object(
        "success", &T::success,
        "series", &T::series,
        "statistics", &T::statistics,
        "errorMessage", &T::errorMessage,
        "errorCode", &T::errorCode,
        "functionMetadata", &T::functionMetadata,
        "originalQuery", &T::originalQuery,
        "parsedQuery", &T::parsedQuery
    );
};

template<>
struct glz::meta<tsdb::FunctionQueryResponse::FunctionMetadata> {
    using T = tsdb::FunctionQueryResponse::FunctionMetadata;
    static constexpr auto value = object(
        "functionsExecuted", &T::functionsExecuted,
        "totalFunctionExecutions", &T::totalFunctionExecutions,
        "totalFunctionTimeMs", &T::totalFunctionTimeMs,
        "performanceMetrics", &T::performanceMetrics
    );
};

#endif // __FUNCTION_HTTP_HANDLER_H_INCLUDED__